{
    "name": "pqsound",
    "version": "0.1.0",
    "description": "",
    "scripts": {
        "start": "node --max-old-space-size=128 -r ts-node/register  ./src/start.ts",
        "lint": "eslint --fix --ext .js,.jsx,.ts,.tsx --ignore-path .gitignore .",
        "test": "jest",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "test:e2e": "playwright test --config playwright/playwright.config.ts",
        "test:e2e:ui": "playwright test --config playwright/playwright.config.ts --ui",
        "start:local": "nodemon --config ./utils/nodemon.json",
        "start:local:so": "env SERVER_ONLY=true nodemon --config ./utils/nodemon.json",
        "prepare": "git config core.hooksPath .githooks || exit 0",
        "": "--------------------------------------------------------------------------",
        "build": "rm -rf dist && node -r ts-node/register ./node_modules/webpack/bin/webpack.js --config src/webpackCfg/webpack.config.ts",
        "build:local": "rm -rf dist && cross-env NODE_ENV=local NODE_HOST=local node -r ts-node/register ./node_modules/webpack/bin/webpack.js --config src/webpackCfg/webpack.config.ts"
    },
    "keywords": [
        "express",
        "webpack",
        "node",
        "react",
        "redux",
        "audio",
        "synth"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/ItsMeaga1n/PqSound.git"
    },
    "engines": {
        "node": ">=17.5.0"
    },
    "author": "Patryq",
    "license": "ISC",
    "devDependencies": {
        "@flydotio/dockerfile": "^0.2.7",
        "@playwright/test": "^1.61.1",
        "@types/jest": "^27.5.2",
        "@types/react": "16.9.35",
        "@types/react-dom": "16.9.8",
        "@types/styled-components": "5.1.0",
        "@types/webmidi": "2.0.4",
        "@typescript-eslint/eslint-plugin": "2.31.0",
        "@typescript-eslint/parser": "2.31.0",
        "css-loader": "7.1.4",
        "eslint": "7.32.0",
        "eslint-config-prettier": "^6.11.0",
        "eslint-plugin-prettier": "^3.1.3",
        "eslint-plugin-react": "7.21.5",
        "fork-ts-checker-webpack-plugin": "^9.1.0",
        "jest": "^27.5.1",
        "mini-css-extract-plugin": "^2.9.2",
        "prettier": "^2.0.5",
        "redux-devtools-extension": "2.13.8",
        "source-map-loader": "^5.0.0",
        "style-loader": "1.2.1",
        "ts-jest": "^29.4.11",
        "ts-loader": "^9.5.4"
    },
    "dependencies": {
        "@overnightjs/core": "^1.6.15",
        "@overnightjs/logger": "^1.1.10",
        "@types/express": "4.17.6",
        "cross-env": "7.0.2",
        "express": "^4.18.2",
        "file-loader": "6.0.0",
        "html-webpack-plugin": "^5.6.3",
        "http-status-codes": "^1.4.0",
        "nodemon": "^2.0.4",
        "normalize.css": "8.0.1",
        "npm": "^12.0.1",
        "react": "16.13.1",
        "react-bootstrap": "0.31.5",
        "react-dom": "16.13.1",
        "react-dropzone": "11.2.1",
        "react-loader-spinner": "3.1.14",
        "react-redux": "7.2.0",
        "redux": "4.0.5",
        "redux-logger": "3.0.6",
        "redux-thunk": "2.3.0",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "typescript": "^5.6.3",
        "webpack": "5.108.4",
        "webpack-cli": "^4.10.0",
        "webpack-dev-middleware": "5.3.4",
        "webpack-hot-middleware": "^2.25.3"
    }
}
